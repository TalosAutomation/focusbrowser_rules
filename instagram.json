{
  "domain": "instagram.com",
  "blockedRoutes": [
    "/reels",
    "/explore"
  ],
  "hideSelectors": [
    "a[href='/reels/']",
    "a[href='/explore/']",
    "a[href*='/reels']",
    "a[href*='/explore']",
    "[aria-label='Reels']",
    "[aria-label='Explore']",
    "div[class*='_aang']",
    "div[class*='SuggestedUser']",
    "div[class*='_aaum']"
  ],
  "textFilterPatterns": [
    "\\bSuggested\\s*post(s)?\\b",
    "\\bSuggested\\s*for\\s*you\\b",
    "Suggested post"
  ],
  "adPatterns": [
    "\\bSponsored\\b",
    "\\bPaid partnership\\b",
    "\\bPromoted\\b",
    "Ad"
  ],
  "disableAutoplay": true,
  "delayOpenMs": 3000,
  "grayscale": false,
  "blurThumbnails": false,
  "blurSelectors": [
    "article img",
    "article video",
    "div[role='button'] img",
    "a[href*='/reel/'] img"
  ]
}
