{
    "domain": "youtube.com",
    "blockedRoutes": [
        "/shorts",
        "/feed/trending",
        "/feed/explore"
    ],
    "hideSelectors": [
        "ytd-reel-shelf-renderer",
        "ytd-rich-shelf-renderer[is-shorts]",
        "ytm-shorts-lockup-view-model",
        "ytm-reel-shelf-renderer",
        "a[href*='/shorts/']",
        "ytd-compact-video-renderer",
        "ytd-watch-next-secondary-results-renderer",
        "#related",
        "#items > ytd-compact-video-renderer",
        "ytd-browse[page-subtype='home'] ytd-rich-grid-row",
        ".ytp-suggestion-set",
        ".ytp-endscreen-content",
        "ytd-merch-shelf-renderer",
        "ytd-action-companion-ad-renderer",
        "ytd-promoted-sparkles-web-renderer",
        "ytd-player-legacy-desktop-watch-ads-renderer",
        ".ytm-autonav-toggle-button-container",
        "button[data-a-target='autoplay-toggle']",
        "ytm-pivot-bar-item-renderer[tab-identifier='FEshorts']",
        "ytm-pivot-bar-item-renderer[tab-identifier='FEtrending']"
    ],
    "disableAutoplay": true,
    "delayOpenMs": 3000,
    "grayscale": false,
    "blurThumbnails": false,
    "blurSelectors": [
        "ytd-thumbnail img",
        "ytm-media-item img",
        "#thumbnail img",
        "ytm-shorts-lockup-view-model img",
        ".ytp-videowall-still-image"
    ]
}
